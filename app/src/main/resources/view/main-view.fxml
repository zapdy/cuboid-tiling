<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="rootPane" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.zapdy.cuboidtiling.view.MainController">

   <children>
      <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity">
         <children>

            <HBox alignment="CENTER" prefHeight="51.0" prefWidth="600.0" spacing="10.0">
               <children>
                  <Label text="Width:">
                     <font><Font size="19.0" /></font>
                  </Label>

                  <TextField fx:id="widthTextField" prefWidth="90.0" text="2">
                     <font><Font size="20.0" /></font>
                  </TextField>

                  <Label text="Height:">
                     <font><Font size="20.0" /></font>
                  </Label>

                  <TextField fx:id="heightTextField" prefWidth="90.0" text="2">
                     <font><Font size="20.0" /></font>
                  </TextField>

                  <Label text="Depth">
                     <font><Font size="20.0" /></font>
                  </Label>

                  <TextField fx:id="depthTextField" prefWidth="90.0" text="2">
                     <font><Font size="20.0" /></font>
                  </TextField>

                  <Button fx:id="runButton" text="Run">
                     <font><Font size="20.0" /></font>
                  </Button>
               </children>

               <padding>
                  <Insets bottom="10.0" top="10.0" />
               </padding>
            </HBox>

            <HBox alignment="CENTER">
               <children>
                  <Label fx:id="statusLabel">
                     <font><Font size="16.0" /></font>
                  </Label>
               </children>
            </HBox>

            <ListView fx:id="partitionListView" style="-fx-font-size: 18px;" VBox.vgrow="ALWAYS" />

         </children>
      </VBox>
   </children>
</StackPane>
